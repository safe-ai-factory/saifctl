{
  "name": "safe-ai-factory",
  "version": "0.0.0",
  "description": "Spec-driven AI factory. Use with any agentic CLI. Language-agnostic. Safe by design.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "saif": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "knip": "knip --exclude types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate": "tsx src/commands/cli.ts validate",
    "check": "tsx src/commands/cli.ts check",
    "check:agent": "tsx src/commands/cli.ts check --reporter=agent",
    "agents": "tsx src/commands/cli.ts agents",
    "saif:init": "tsx src/cli/commands/init.ts",
    "saif:feat:new": "tsx src/cli/commands/feat.ts new",
    "saif:feat:design": "tsx src/cli/commands/feat.ts design",
    "saif:feat:design-specs": "tsx src/cli/commands/feat.ts design-specs",
    "saif:feat:design-tests": "tsx src/cli/commands/feat.ts design-tests",
    "saif:feat:design-fail2pass": "tsx src/cli/commands/feat.ts design-fail2pass",
    "agents:feat:run": "pnpm agents feat:run --model openrouter/anthropic/claude-sonnet-4.6",
    "agents:feat:continue": "pnpm agents feat:continue --model openrouter/anthropic/claude-sonnet-4.6",
    "agents:feat:assess": "pnpm agents feat:assess",
    "agents:feat:finish": "pnpm agents feat:finish",
    "saif:feat:debug": "tsx src/cli/commands/feat.ts debug",
    "docker": "tsx scripts/docker.ts",
    "docker:build:test": "pnpm docker build test",
    "docker:build:coder": "pnpm docker build coder",
    "docker:build:coder-base": "pnpm docker build coder-base",
    "docker:build:stage": "pnpm docker build stage",
    "docker:clear": "pnpm docker clear",
    "cache": "tsx src/cli/commands/cache.ts",
    "cache:list": "tsx src/cli/commands/cache.ts list",
    "cache:clear": "tsx src/cli/commands/cache.ts clear",
    "openspec": "openspec",
    "shotgun": "uv run python -m shotgun.main"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.10",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/baseten": "^1.0.38",
    "@ai-sdk/cerebras": "^2.0.39",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/deepinfra": "^2.0.39",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/fireworks": "^2.0.40",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/huggingface": "^1.0.37",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/moonshotai": "^2.0.10",
    "@ai-sdk/openai": "^3.0.34",
    "@ai-sdk/perplexity": "^3.0.23",
    "@ai-sdk/togetherai": "^2.0.39",
    "@ai-sdk/vercel": "^2.0.37",
    "@ai-sdk/xai": "^3.0.67",
    "@clack/prompts": "^1.0.1",
    "@mastra/core": "^1.7.0",
    "citty": "^0.2.1",
    "dockerode": "^4.0.9",
    "fast-xml-parser": "^5.4.2",
    "minimatch": "^10.2.4",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@fission-ai/openspec": "^1.2.0",
    "@strongdm/leash": "^1.1.6",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "knip": "^5.85.0",
    "prettier": "^3",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}