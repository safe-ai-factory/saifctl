# Coder image — python-conda sandbox profile.
#
# Based on continuumio/miniconda3 (conda pre-installed).
# No Node.js — use python-conda-node if you need Node-based coder agents.
#
# Build:
#   docker build -f src/sandbox-profiles/python-conda/Dockerfile.coder \
#                -t saifctl-coder-python-conda:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-conda
FROM continuumio/miniconda3:latest

ENV DEBIAN_FRONTEND=noninteractive

# Put conda on PATH.
ENV PATH="/opt/conda/bin:$PATH"

# Add common utilities beyond the Miniconda base image.
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  git \
  && rm -rf /var/lib/apt/lists/*

# Refresh conda and clean package cache.
RUN conda update -n base -c conda-forge conda --yes \
  && conda clean -afy

# Enable conda for login shells.
RUN conda init bash

# ─── Drop-privileges scaffold (release-readiness/X-08-P2) ───────────────────────────────────────
# Some agent CLIs (notably Claude Code with `--dangerously-skip-permissions`)
# refuse to run as root. The container default stays root for Leash bootstrap
# compatibility; per-agent scripts drop to this user via `runuser` for the
# agent invocation only. See src/agent-profiles/claude/agent.sh.
RUN useradd -m -s /bin/bash saifctl \
  && mkdir -p /home/saifctl/.npm-global \
  && chown -R saifctl:saifctl /home/saifctl
ENV SAIFCTL_UNPRIV_USER=saifctl
ENV SAIFCTL_UNPRIV_NPM_PREFIX=/home/saifctl/.npm-global
