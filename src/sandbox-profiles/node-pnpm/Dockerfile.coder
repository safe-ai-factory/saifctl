# Coder image — node-pnpm sandbox profile.
#
# Based on official Node.js image.
# Adds git and pnpm. No Python toolchain — use node-pnpm-python if you need Python-based
# coder agents (OpenHands, Aider, etc.).
#
# Build:
#   docker build -f src/sandbox-profiles/node-pnpm/Dockerfile.coder \
#                -t saifctl-coder-node-pnpm:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile node-pnpm
ARG NODE_VERSION=25
FROM node:${NODE_VERSION}-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

# Add common utilities.
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  git \
  && rm -rf /var/lib/apt/lists/*

# Install pnpm globally.
RUN npm install -g pnpm

# ─── Drop-privileges scaffold ────────────────────────────────────────────────
# The container runs as root by default — Leash's bootstrap mounts (/leash,
# /log, /cfg, /leash-private) are root-owned on the host and would be
# unreadable to a non-root container. However, several agent CLIs (notably
# Claude Code 2.x with `--dangerously-skip-permissions`) refuse to run as
# root for security reasons. We pre-create a `saifctl` user with a writable
# npm-global prefix so per-agent scripts (`agent.sh`) can `runuser -u saifctl`
# for the agent invocation only, leaving Leash's privileged paths untouched.
#
# Pre-creating the user in the image (vs `useradd` at runtime in agent.sh)
# avoids the ~200ms apt/useradd cost on every round and keeps the container
# image as the single source of truth for "the unprivileged user is named
# saifctl, has $HOME set, and has $NPM_CONFIG_PREFIX writable".
RUN useradd -m -s /bin/bash saifctl \
  && mkdir -p /home/saifctl/.npm-global \
  && chown -R saifctl:saifctl /home/saifctl
ENV SAIFCTL_UNPRIV_USER=saifctl
ENV SAIFCTL_UNPRIV_NPM_PREFIX=/home/saifctl/.npm-global
