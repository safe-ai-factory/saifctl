# Coder image — go-node-python sandbox profile.
#
# Extends coder-base (which provides coder-start.sh) with the Go toolchain,
# Node.js 22 LTS, and Python 3 + pip + uv. Go is the primary runtime; Node.js
# and Python are included on the side so both Node-based (claude-code, codex)
# and Python-based (OpenHands, Aider) coder agents can be bootstrapped by
# agent-start.sh.
#
# Build:
#   docker build -f src/sandbox-profiles/go-node-python/Dockerfile.coder \
#                -t factory-coder-go-node-python:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile go-node-python
FROM factory-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Go, Python toolchain, and git (required by most coder agents).
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    golang \
    python3 \
    python3-venv \
    python3-pip \
    pipx \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install uv so Python-based agent-start scripts can use it.
RUN pipx install uv --python python3

# Ensure Go and pipx-managed binaries are on PATH.
ENV GOPATH="/root/go"
ENV PATH="$GOPATH/bin:/root/.local/bin:$PATH"
