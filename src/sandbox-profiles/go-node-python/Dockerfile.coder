# Coder image — go-node-python sandbox profile.
#
# Based on official golang image.
# Adds Node.js (NodeSource) and a Python toolchain with uv (pipx).
#
# Build:
#   docker build -f src/sandbox-profiles/go-node-python/Dockerfile.coder \
#                -t saifctl-coder-go-node-python:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile go-node-python
ARG GO_VERSION=1.23
FROM golang:${GO_VERSION}-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# Configure GOPATH; pipx binaries will be merged into PATH below.
ENV GOPATH="/root/go"
ENV PATH="$GOPATH/bin:/root/.local/bin:$PATH"

ARG NODE_MAJOR=25
# Add Python toolchain (pipx) and Node.js (NodeSource).
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  gnupg \
  python3 \
  python3-venv \
  python3-pip \
  pipx \
  && install -d -m 0755 /etc/apt/keyrings \
  && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
  && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
  && apt-get update && apt-get install -y --no-install-recommends nodejs \
  && rm -rf /var/lib/apt/lists/*

# Symlink pipx-managed uv into /usr/local/bin so it stays on PATH in minimal shells.
RUN pipx install uv --python python3 \
  && ln -sf /root/.local/bin/uv /usr/local/bin/uv
