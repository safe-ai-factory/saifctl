# Coder image — node-bun sandbox profile.
#
# Based on official Node.js image.
# Adds Bun (bun.sh); keeps npm/npx for Node-based agent CLIs.
# No Python toolchain — use node-bun-python if you need Python-based coder agents.
#
# Build:
#   docker build -f src/sandbox-profiles/node-bun/Dockerfile.coder \
#                -t saifctl-coder-node-bun:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile node-bun
ARG NODE_VERSION=25
FROM node:${NODE_VERSION}-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

# Add common utilities and install Bun.
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  git \
  unzip \
  && curl -fsSL https://bun.sh/install | bash \
  && rm -rf /var/lib/apt/lists/*

# Put Bun on PATH.
ENV PATH="/root/.bun/bin:$PATH"

# ─── Drop-privileges scaffold (release-readiness/X-08-P2) ───────────────────────────────────────
# Some agent CLIs (notably Claude Code with `--dangerously-skip-permissions`)
# refuse to run as root. The container default stays root for Leash bootstrap
# compatibility; per-agent scripts drop to this user via `runuser` for the
# agent invocation only. See src/agent-profiles/claude/agent.sh.
RUN useradd -m -s /bin/bash saifctl \
  && mkdir -p /home/saifctl/.npm-global \
  && chown -R saifctl:saifctl /home/saifctl
ENV SAIFCTL_UNPRIV_USER=saifctl
ENV SAIFCTL_UNPRIV_NPM_PREFIX=/home/saifctl/.npm-global
