# Coder image — go-python sandbox profile.
#
# Based on official golang image.
# Adds a Python toolchain and uv (pipx) for Python-based coder agents.
#
# Build:
#   docker build -f src/sandbox-profiles/go-python/Dockerfile.coder \
#                -t saifctl-coder-go-python:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile go-python
ARG GO_VERSION=1.23
FROM golang:${GO_VERSION}-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# Configure GOPATH; pipx binaries will be merged into PATH below.
ENV GOPATH="/root/go"
ENV PATH="$GOPATH/bin:/root/.local/bin:$PATH"

# Add Python toolchain (pipx).
RUN apt-get update && apt-get install -y --no-install-recommends \
  python3 \
  python3-venv \
  python3-pip \
  pipx \
  && rm -rf /var/lib/apt/lists/*

# Symlink pipx-managed uv into /usr/local/bin so it stays on PATH in minimal shells.
RUN pipx install uv --python python3 \
  && ln -sf /root/.local/bin/uv /usr/local/bin/uv

# ─── Drop-privileges scaffold (release-readiness/X-08-P2) ───────────────────────────────────────
# Some agent CLIs (notably Claude Code with `--dangerously-skip-permissions`)
# refuse to run as root. The container default stays root for Leash bootstrap
# compatibility; per-agent scripts drop to this user via `runuser` for the
# agent invocation only. See src/agent-profiles/claude/agent.sh.
RUN useradd -m -s /bin/bash saifctl \
  && mkdir -p /home/saifctl/.npm-global \
  && chown -R saifctl:saifctl /home/saifctl
ENV SAIFCTL_UNPRIV_USER=saifctl
ENV SAIFCTL_UNPRIV_NPM_PREFIX=/home/saifctl/.npm-global
