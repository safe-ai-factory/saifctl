# Coder image — python-uv-node sandbox profile.
#
# Extends coder-base (which provides coder-start.sh) with Python 3, uv, and Node.js.
# Python is the primary runtime; Node.js 22 LTS is included on the side so Node-based
# coder agents (claude-code, codex, etc.) can be installed at runtime by agent-start.sh.
#
# Build:
#   docker build -f src/sandbox-profiles/python-uv-node/Dockerfile.coder \
#                -t saifac-coder-python-uv-node:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-uv-node
FROM saifac-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Python toolchain, uv, and Node.js 22 LTS.
# Python is the primary runtime; Node.js is included so Node-based coder agents
# can be bootstrapped by agent-start.sh.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    python3 \
    python3-venv \
    && curl -fsSL https://astral.sh/uv/install.sh | sh \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin:$PATH"
