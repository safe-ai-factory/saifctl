# Coder image — python-uv sandbox profile.
#
# Based on official Python image.
# Installs uv via astral.sh (not pipx). No Node.js — use python-uv-node if you need Node-based coder agents.
#
# Build:
#   docker build -f src/sandbox-profiles/python-uv/Dockerfile.coder \
#                -t saifctl-coder-python-uv:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-uv
ARG PYTHON_VERSION=3.13
FROM python:${PYTHON_VERSION}-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# Add common utilities and install uv (astral.sh).
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  git \
  && curl -fsSL https://astral.sh/uv/install.sh | sh \
  && rm -rf /var/lib/apt/lists/*

# Ensure uv-installed binaries are on PATH.
ENV PATH="/root/.local/bin:$PATH"

# ─── Drop-privileges scaffold (release-readiness/X-08-P2) ───────────────────────────────────────
# Some agent CLIs (notably Claude Code with `--dangerously-skip-permissions`)
# refuse to run as root. The container default stays root for Leash bootstrap
# compatibility; per-agent scripts drop to this user via `runuser` for the
# agent invocation only. See src/agent-profiles/claude/agent.sh.
RUN useradd -m -s /bin/bash saifctl \
  && mkdir -p /home/saifctl/.npm-global \
  && chown -R saifctl:saifctl /home/saifctl
ENV SAIFCTL_UNPRIV_USER=saifctl
ENV SAIFCTL_UNPRIV_NPM_PREFIX=/home/saifctl/.npm-global
