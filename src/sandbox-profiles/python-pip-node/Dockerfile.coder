# Coder image — python-pip-node sandbox profile.
#
# Extends coder-base (which provides coder-start.sh) with Python 3, pip, and uv.
# Node.js 22 LTS is included on the side so Node-based coder agents (claude-code,
# codex, etc.) can be installed at runtime by agent-start.sh.
#
# Build:
#   docker build -f src/sandbox-profiles/python-pip-node/Dockerfile.coder \
#                -t factory-coder-python-pip-node:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-pip-node
FROM factory-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Python toolchain and Node.js 22 LTS.
# Python is the primary runtime; Node.js is included so Node-based coder agents
# can be bootstrapped by agent-start.sh.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    python3 \
    python3-venv \
    python3-pip \
    pipx \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install uv — the primary Python package manager for this profile.
RUN pipx install uv --python python3

# Ensure pipx-managed binaries are on PATH.
ENV PATH="/root/.local/bin:$PATH"
