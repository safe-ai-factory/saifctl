# Coder image — rust-node-python sandbox profile.
#
# Extends coder-base (which provides coder-start.sh) with the Rust toolchain,
# Node.js 22 LTS, and Python 3 + pip + uv. Rust is the primary runtime; Node.js
# and Python are included on the side so both Node-based (claude-code, codex)
# and Python-based (OpenHands, Aider) coder agents can be bootstrapped by
# agent-start.sh.
#
# Build:
#   docker build -f src/sandbox-profiles/rust-node-python/Dockerfile.coder \
#                -t factory-coder-rust-node-python:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile rust-node-python
FROM factory-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install build dependencies, Python toolchain, git, and Node.js 22 LTS.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    pkg-config \
    python3 \
    python3-venv \
    python3-pip \
    pipx \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Rust via rustup (stable channel + clippy + rustfmt).
RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --component clippy rustfmt

# Install uv so Python-based agent-start scripts can use it.
RUN pipx install uv --python python3

# Ensure cargo and pipx-managed binaries are on PATH.
ENV PATH="/root/.cargo/bin:/root/.local/bin:$PATH"
