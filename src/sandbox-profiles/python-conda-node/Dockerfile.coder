# Coder image — python-conda-node sandbox profile.
#
# Extends coder-base (which provides coder-start.sh) with Miniconda (conda + Python)
# and Node.js 22 LTS. Python is the primary runtime; Node.js is included on the side
# so Node-based coder agents (claude-code, codex, etc.) can be installed at runtime
# by agent-start.sh.
#
# Build:
#   docker build -f src/sandbox-profiles/python-conda-node/Dockerfile.coder \
#                -t saifac-coder-python-conda-node:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-conda-node
FROM saifac-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/opt/conda/bin:$PATH"

# Install git, Miniconda, and Node.js 22 LTS.
# Python is the primary runtime; Node.js is included so Node-based coder agents
# can be bootstrapped by agent-start.sh.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    wget \
    && wget -qO /tmp/miniconda.sh https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh \
    && bash /tmp/miniconda.sh -b -p /opt/conda \
    && rm /tmp/miniconda.sh \
    && conda update -n base -c defaults conda --yes \
    && conda clean -afy \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Configure conda for non-interactive shell use.
RUN conda init bash
