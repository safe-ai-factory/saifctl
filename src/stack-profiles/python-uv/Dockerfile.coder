# Coder image — python-uv stack profile.
#
# Extends coder-base (which provides coder-start.sh) with Python 3 and uv.
# uv is the primary package manager (no pip). No Node.js — use python-pip-node
# if you need Node-based coder agents (claude-code, codex, etc.).
#
# Build:
#   docker build -f src/stack-profiles/python-uv/Dockerfile.coder \
#                -t factory-coder-python-uv:latest .
#
# Or via CLI:
#   pnpm docker build coder --profile python-uv
FROM factory-coder-base:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Python toolchain and git (required by most coder agents).
# uv is installed via the official installer (faster, no pip dependency).
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    python3 \
    python3-venv \
    && curl -fsSL https://astral.sh/uv/install.sh | sh \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin:$PATH"
