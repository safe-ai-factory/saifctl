{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src",
    "scripts",
    "saifctl",
    "test/integration",
    "tsup.config.ts",
    "eslint.config.js",
    "vitest.config.ts",
    "vitest.integration.config.ts"
  ],
  "exclude": ["node_modules", "dist", "test/integration/harness/fixtures/**"]
}
