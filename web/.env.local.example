# Supabase - https://app.supabase.com/project/<your-project>/settings/api
# Host your project in the EU (Frankfurt/London) for GDPR compliance.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Plausible Analytics - https://plausible.io (or your self-hosted instance)
# Set to your site's domain, e.g. safeaifactory.com
# Leave empty to disable analytics (e.g. in local dev).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=safeaifactory.com
